% Tento balíček obsahuje nastavenia pre záverečné práce na UNIZA, ktoré sa používajú v hlavnom súbore sablona_dp.tex. V hlavnom súbore sa nastavujú premenné, ktoré sa tu používajú, a tento balíček sa načítava pomocou \usepackage{uniza_zp}.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{uniza_zp}[2024/06/01 v1.0 Šablóna pre záverečné práce na UNIZA]

% ----- konfigurácia balíkov -----
\RequirePackage[T1]{fontenc}
\RequirePackage{tocloft}
\RequirePackage{tocbasic}
\RequirePackage{tabularx} % balíček pre tabulky
\RequirePackage{graphicx}
\RequirePackage{geometry}
\RequirePackage{amsmath} % balíček pre matematické vzorce
\RequirePackage{float}
\RequirePackage[framemethod=tikz]{mdframed}
\RequirePackage{ragged2e}
\RequirePackage{caption}
\RequirePackage{hyperref}
\RequirePackage{fancyhdr}
\RequirePackage{indentfirst} % odsadenie prvého riadku v odseku
\RequirePackage{pdfpages}
\RequirePackage{moreverb}
\RequirePackage{subcaption}
\RequirePackage{notoccite} % nezoraďovať citácie podľa obsahu
\RequirePackage[slovak]{babel}
\RequirePackage{xparse}

% ----- nastavenie typu písma -----
\usepackage{helvet} % arial font
\renewcommand{\familydefault}{\sfdefault}

% ----- nastavenie hlavičky a päty -----
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\rfoot{\thepage}
\fancypagestyle{plain}{
	\fancyhf{}
	\fancyhead{}
	\fancyfoot{}
	\rfoot{\thepage}
	\renewcommand{\headrulewidth}{0pt}
	\renewcommand{\footrulewidth}{0pt}
}

% ----- nastavenie popisov obrázkov a tabuliek -----
\captionsetup[table]{labelsep=space}
\captionsetup[table]{justification=raggedleft,singlelinecheck=off}
\captionsetup[figure]{labelsep=space}

% ----- nastavenie okrajov, odsadenia a riadkovania -----
\parskip=5pt plus 1pt
\renewcommand{\baselinestretch}{1.5}
\geometry{
	a4paper,
	left=3.5cm,
	right=2.5cm,
	top=1.25cm,
	bottom=1.25cm,
	headheight=0.5cm,
	includefoot,
	includehead
}

% ----- konfigurácia pomenovania zoznamov a popisov -----
\renewcommand{\cftsecleader}{\cftdotfill{\cftdotsep}}
\addto\captionsslovak{
	\renewcommand{\contentsname}{Obsah}
}
\newcommand\entrynumberwithprefix[2]{#1\enspace#2:\hfill}
\DeclareTOCStyleEntry[ % pridanie obr. pred názov obrázku do zoznamu obrázkov
entrynumberformat=\entrynumberwithprefix{\figurename},
dynnumwidth,
numsep=1em
]{tocline}{figure}
\DeclareTOCStyleEntry[ % pridanie tab. pred názov tabuľky
entrynumberformat=\entrynumberwithprefix{\tablename},
dynnumwidth,
numsep=1em
]{tocline}{table}

% ----- konfigurácia pomenovania zoznamov a popisov -----
\addto\captionsslovak{
	\renewcommand{\listfigurename}{Zoznam obrázkov}
	\renewcommand{\listtablename}{Zoznam tabuliek}
	\renewcommand{\refname}{Zoznam použitej literatúry}
	\renewcommand{\figurename}{Obr.} % úprava popisov pre obrázky
	\counterwithin{figure}{section} % štrukturované číslovanie obrázkov
	\renewcommand{\tablename}{Tab.} % zmena popisu tabuľky
	\counterwithin{table}{section}
	\counterwithin{equation}{section}
	\renewcommand{\thefigure}{\arabic{figure}}
	\renewcommand{\thetable}{\arabic{table}}
}

% ----- vytvorenie zoznamu pre prílohy -----
\newcommand{\listexamplename}{\Large Zoznam príloh}
\newlistof{example}{exp}{\listexamplename}
\newcounter{examplealph}
\newcommand{\example}[1]{%
	\refstepcounter{examplealph}
	\par\noindent\section*{Príloha \Alph{examplealph}: #1}
	\addcontentsline{exp}{example}
	{\textbf{Príloha \protect\numberline{\Alph{examplealph}}}#1}\par}
\renewcommand{\theexamplealph}{\Alph{examplealph}}

\graphicspath{{images/}} % priečinok odkiaľ sa načítavajú obrázky

