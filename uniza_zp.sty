}
\newcommand\entrynumberwithprefix[2]{#1\enspace#2:\hfill}
\DeclareTOCStyleEntry[ % pridanie obr. pred názov obrázku do zoznamu obrázkov
entrynumberformat=\entrynumberwithprefix{\figurename},
dynnumwidth,
numsep=1em
]{tocline}{figure}
\DeclareTOCStyleEntry[ % pridanie tab. pred názov tabuľky
entrynumberformat=\entrynumberwithprefix{\tablename},
dynnumwidth,
numsep=1em
]{tocline}{table}

% ----- konfigurácia pomenovania zoznamov a popisov -----
\addto\captionsslovak{
	\renewcommand{\listfigurename}{Zoznam obrázkov}
	\renewcommand{\listtablename}{Zoznam tabuliek}
	\renewcommand{\refname}{Zoznam použitej literatúry}
	\renewcommand{\figurename}{Obr.} % úprava popisov pre obrázky
	\counterwithin{figure}{section} % štrukturované číslovanie obrázkov
	\renewcommand{\tablename}{Tab.} % zmena popisu tabuľky
	\counterwithin{table}{section}
	\counterwithin{equation}{section}
	\renewcommand{\thefigure}{\arabic{figure}}
	\renewcommand{\thetable}{\arabic{table}}
}

% ----- vytvorenie zoznamu pre prílohy -----
\newcommand{\listprilohaname}{\Large Zoznam príloh}
\newlistof{priloha}{exp}{\listprilohaname}
\newcounter{prilohaalph}
\newcommand{\priloha}[1]{%
	\refstepcounter{prilohaalph}
	\par\noindent\section*{Príloha \Alph{prilohaalph}: #1}
	\addcontentsline{exp}{priloha}
	{\textbf{Príloha \protect\numberline{\Alph{prilohaalph}}}#1}\par}
\renewcommand{\theprilohaalph}{\Alph{prilohaalph}}

\graphicspath{{images/}} % priečinok odkiaľ sa načítavajú obrázky

% ----- miesto pre ukladanie skratiek a symbolov -----
\newglossary[abg]{unizaabbr}{abl}{abx}{Zoznam skratiek}
\newglossary[syg]{unizasymbol}{syl}{syx}{Zoznam symbolov}
\makeglossaries
\ExplSyntaxOn
\int_new:N \g_uniza_abbr_int
\int_new:N \g_uniza_symbol_int
\bool_new:N \g_uniza_glossary_started_bool
\tl_new:N \g_uniza_pending_abbr_tl
\tl_new:N \g_uniza_pending_symbol_tl

\AtBeginDocument{
	\bool_gset_true:N \g_uniza_glossary_started_bool
}

\cs_new_protected:Npn \uniza_flush_pending_gls:
	{
			\tl_use:N \g_uniza_pending_abbr_tl
			\tl_use:N \g_uniza_pending_symbol_tl
			\tl_gclear:N \g_uniza_pending_abbr_tl
			\tl_gclear:N \g_uniza_pending_symbol_tl
	}

\cs_new_protected:Npn \uniza_define_abbr_entry:nnn #1#2#3
	{
		\int_gincr:N \g_uniza_abbr_int
		\tl_set:Nx \l_tmpa_tl { unizaabbr\int_use:N \g_uniza_abbr_int }
		\newglossaryentry{\l_tmpa_tl}{%
			type=unizaabbr,
			name={#1},
			description={#2},
			user1={#3}%
		}
		\bool_if:NTF \g_uniza_glossary_started_bool
			{ \glsadd{\l_tmpa_tl} }
			{ \tl_gput_right:Nn \g_uniza_pending_abbr_tl { \glsadd{\l_tmpa_tl} } }
	}

\cs_new_protected:Npn \uniza_define_symbol_entry:nnn #1#2#3
	{
		\int_gincr:N \g_uniza_symbol_int
		\tl_set:Nx \l_tmpa_tl { unizasymbol\int_use:N \g_uniza_symbol_int }
		\newglossaryentry{\l_tmpa_tl}{%
			type=unizasymbol,
			name={#1},
			description={#2},
			user1={#3}%
		}
		\bool_if:NTF \g_uniza_glossary_started_bool
			{ \glsadd{\l_tmpa_tl} }
			{ \tl_gput_right:Nn \g_uniza_pending_symbol_tl { \glsadd{\l_tmpa_tl} } }
	}

\cs_new_protected:Npn \skratka #1#2#3
	{
		\uniza_define_abbr_entry:nnn {#1}{#2}{#3}
	}

\cs_new_protected:Npn \velicina #1#2#3
	{
		\uniza_define_symbol_entry:nnn {#1}{#2}{#3}
	}
\ExplSyntaxOff

\newglossarystyle{unizaabbrevthreecol}{%
	\setglossarystyle{long3col}%
	\setlength{\glsdescwidth}{0.27\textwidth}%
	\setlength{\glspagelistwidth}{0.56\textwidth}%
	\renewcommand*{\glossaryheader}{%
		\bfseries Skratka &
		\bfseries Anglický význam &
		\bfseries Slovenský význam\tabularnewline
	\endhead}%
	\renewcommand*{\glossentry}[2]{%
		\glsentryitem{##1}\glstarget{##1}{\glossentryname{##1}} &
		\glossentrydesc{##1} &
		\glsentryuseri{##1}\tabularnewline
	}%
}

\newglossarystyle{unizasymbolthreecol}{%
	\setglossarystyle{long3col}%
	\setlength{\glsdescwidth}{0.25\textwidth}%
	\setlength{\glspagelistwidth}{0.58\textwidth}%
	\renewcommand*{\glossaryheader}{%
		\bfseries Symbol &
		\bfseries Jednotka &
		\bfseries Význam symbolu\tabularnewline
	\endhead}%
	\renewcommand*{\glossentry}[2]{%
		\glsentryitem{##1}\glstarget{##1}{\glossentryname{##1}} &
		\glossentrydesc{##1} &
		\glsentryuseri{##1}\tabularnewline
	}%
}

\newcommand{\zoznamskratiek}{%
	\printglossary[type=unizaabbr,style=unizaabbrevthreecol]%
}

\newcommand{\zoznamsymbolov}{%
	\printglossary[type=unizasymbol,style=unizasymbolthreecol]%
}

